# ─────────────────────────────────────────────────────────────────
# ZHeat Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────────

# ── Google Sheets ─────────────────────────────────────────────────
# 1. Go to https://sheets.google.com → create a sheet named "ZHeat Quotes"
# 2. Copy the ID from the URL:
#    https://docs.google.com/spreadsheets/d/THIS_IS_YOUR_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# 3. Go to https://console.cloud.google.com
# 4. Create a project → Enable "Google Sheets API"
# 5. Credentials → Create Service Account → Download JSON key
# 6. Open the JSON file and copy these two values:
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Note: Keep the quotes around the private key. Replace \n with actual newlines if needed.

# 7. In your Google Sheet → Share → paste the GOOGLE_CLIENT_EMAIL → Editor access

# ── Gmail (Nodemailer) ────────────────────────────────────────────
# The Gmail account that SENDS notification emails
GMAIL_USER=zhivamweb@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get it:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification (required)
# 3. Search "App passwords" → Select app: Mail → Device: Other → type "ZHeat"
# 4. Copy the 16-character password (e.g. abcd efgh ijkl mnop)
GMAIL_APP_PASSWORD=your_16_character_app_password_here

# The email address that RECEIVES quote notifications
GMAIL_NOTIFY_TO=zhivamweb@gmail.com
